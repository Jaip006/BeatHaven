# BeatHaven Server — Environment Variables

# Application
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:5173
# Optional: additional allowed origins (comma-separated), e.g.
# FRONTEND_URLS=https://beathaven.vercel.app,https://beathaven-git-main-username.vercel.app
FRONTEND_URLS=

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/beathaven?retryWrites=true&w=majority

# JWT Secrets (must be at least 32 characters)
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_min_32_chars

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Service (Nodemailer SMTP)
# Required in production for OTP signup/verification
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_app_password
EMAIL_FROM="BeatHaven <no-reply@yourdomain.com>"

# SMS (Twilio) - optional unless you use mobile OTP features
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155552671
# Optional: use Messaging Service instead of direct From number
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid
